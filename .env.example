# ESMP Environment Configuration
# Copy to .env and customize. Docker Compose reads .env automatically.
# WARNING: Never commit .env if you add real credentials.

# Database passwords
NEO4J_PASSWORD=esmp-local-password
MYSQL_PASSWORD=esmp-local-password
MYSQL_ROOT_PASSWORD=esmp-local-root
GRAFANA_PASSWORD=admin

# Source access strategy: VOLUME_MOUNT or GITHUB_URL
ESMP_SOURCE_STRATEGY=VOLUME_MOUNT

# For VOLUME_MOUNT: path on host to bind-mount as /mnt/source (default: current directory)
SOURCE_ROOT=./

# For GITHUB_URL: repository URL and authentication
ESMP_SOURCE_GITHUB_URL=
ESMP_SOURCE_GITHUB_TOKEN=
ESMP_SOURCE_BRANCH=main
